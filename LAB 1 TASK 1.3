#include<iostream>
#include<string>
using namespace std;

template <typename T>
int linersearch(T arr[],int size,T find) {
	for (int i = 0; i < size; i++) {
		if (arr[i] == find)
			return i;
	}

	return -1;

}

template <typename T>
void printresult(int index, T find) {
	if (index != -1) {
		cout << find << " find at index " << index << endl;
	}
	else {
		cout << "Sorry not found\n";
	}

}



int main() {
	int arr[5] = { 20,30,76,90,15 };
	int find = 20;
	int index = linersearch(arr, 5,find);
	printresult(index, find);

	string arr2[4] = { "apple", "orange", "banana", "grape" };
	string find2 = "banana";
	int index2 = linersearch(arr2, 4, find2);
	printresult(index2, find2);



	return 0;
}
