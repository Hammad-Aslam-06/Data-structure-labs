#include <iostream>
using namespace std;

class Node {
public:
    int data;
    Node* next;

    Node(int value) {
        data = value;
        next = nullptr;
    }
};

class PatientList {
private:
    Node* head;

public:
    PatientList() {
        head = nullptr;
    }

    void addPatient(int id) {
        Node* newNode = new Node(id);

        if (head == nullptr) {
            head = newNode;
            return;
        }

        Node* temp = head;
        while (temp->next != nullptr) {
            temp = temp->next;
        }

        temp->next = newNode;
    }

    void removePatient(int id) {
        if (head == nullptr) return;

        if (head->data == id) {
            Node* temp = head;
            head = head->next;
            delete temp;
            return;
        }

        Node* temp = head;
        while (temp->next != nullptr && temp->next->data != id) {
            temp = temp->next;
        }

        if (temp->next != nullptr) {
            Node* del = temp->next;
            temp->next = del->next;
            delete del;
        }
    }

    void display() {
        Node* temp = head;

        while (temp != nullptr) {
            cout << temp->data << " ";
            temp = temp->next;
        }
        cout << endl;
    }

    void count() {
        Node* temp = head;
        int c = 0;

        while (temp != nullptr) {
            c++;
            temp = temp->next;
        }

        cout << c << endl;
    }
};

int main() {
    PatientList p;

    p.addPatient(1001);
    p.addPatient(1002);
    p.addPatient(1003);

    p.display();

    p.removePatient(1002);

    p.display();

    p.count();

    return 0;
}
